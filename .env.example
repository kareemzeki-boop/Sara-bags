# ─── Sara Bags Backend — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values
# Never commit .env to git

# Server
PORT=3001
NODE_ENV=development

# Database (SQLite file path — leave default for local dev)
DB_PATH=./data/sara_bags.db

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,https://sarabags.vercel.app

# Admin panel access key (change this to something strong!)
ADMIN_KEY=change-me-to-something-strong

# WhatsApp Business number (digits only, no + or spaces)
# e.g. UAE number: 971501234567
WHATSAPP_NUMBER=971501234567

# Email notifications (optional — leave blank to skip)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
NOTIFY_EMAIL=orders@sarabags.com
